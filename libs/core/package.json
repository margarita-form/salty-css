{
  "name": "@salty-css/core",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Vite plugin for Salty CSS",
  "homepage": "https://salty-css.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/margarita-form/salty-css.git",
    "directory": "libs/core"
  },
  "bugs": {
    "url": "https://github.com/margarita-form/salty-css/issues"
  },
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "test": "vitest run"
  },
  "dependencies": {
    "color": ">=5.x",
    "commander": ">=15.x",
    "csstype": "^3.2.x",
    "ejs": ">=6.x",
    "esbuild": ">=0.28.x",
    "ora": ">=8.x",
    "react": ">=18.x || >=19.x",
    "typescript": ">=5.x",
    "winston": ">=3.x"
  },
  "nx": {
    "targets": {
      "build": {
        "dependsOn": [
          "^build"
        ]
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    "./bin": {
      "import": "./dist/bin/index.js",
      "require": "./dist/bin/index.cjs"
    },
    "./bin/main": {
      "import": "./dist/bin/main.js",
      "require": "./dist/bin/main.cjs"
    },
    "./compiler/salty-compiler": {
      "import": "./dist/compiler/salty-compiler.js",
      "require": "./dist/compiler/salty-compiler.cjs"
    },
    "./compiler/get-files": {
      "import": "./dist/compiler/get-files.js",
      "require": "./dist/compiler/get-files.cjs"
    },
    "./compiler/get-function-range": {
      "import": "./dist/compiler/get-function-range.js",
      "require": "./dist/compiler/get-function-range.cjs"
    },
    "./compiler/helpers": {
      "import": "./dist/compiler/helpers.js",
      "require": "./dist/compiler/helpers.cjs"
    },
    "./factories": {
      "import": "./dist/factories/index.js",
      "require": "./dist/factories/index.cjs"
    },
    "./css": {
      "import": "./dist/css/index.js",
      "require": "./dist/css/index.cjs"
    },
    "./css/keyframes": {
      "import": "./dist/css/keyframes.js",
      "require": "./dist/css/keyframes.cjs"
    },
    "./css/media": {
      "import": "./dist/css/media.js",
      "require": "./dist/css/media.cjs"
    },
    "./css/token": {
      "import": "./dist/css/token.js",
      "require": "./dist/css/token.cjs"
    },
    "./css/merge": {
      "import": "./dist/css/merge.js",
      "require": "./dist/css/merge.cjs"
    },
    "./helpers": {
      "import": "./dist/helpers/index.js",
      "require": "./dist/helpers/index.cjs"
    },
    "./generators": {
      "import": "./dist/generators/index.js",
      "require": "./dist/generators/index.cjs"
    },
    "./parsers": {
      "import": "./dist/parsers/index.js",
      "require": "./dist/parsers/index.cjs"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "require": "./dist/config/index.cjs"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.cjs"
    },
    "./util": {
      "import": "./dist/util/index.js",
      "require": "./dist/util/index.cjs"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./instances/classname-instance": {
      "import": "./dist/instances/classname-instance.js",
      "require": "./dist/instances/classname-instance.cjs"
    },
    "./runtime": {
      "import": "./dist/runtime/index.js",
      "require": "./dist/runtime/index.cjs"
    }
  },
  "bin": {
    "salty": "./dist/bin/index.js",
    "salty-css": "./dist/bin/index.js",
    "salty-css-cjs": "./dist/bin/index.cjs",
    "@salty-css/core": "./dist/bin/index.js"
  },
  "author": {
    "name": "Teemu Lahjalahti",
    "url": "https://www.linkedin.com/in/teemulahjalahti/"
  },
  "keywords": [
    "salty-css",
    "css-in-js",
    "css",
    "styling",
    "build-time",
    "compiler",
    "design-tokens"
  ],
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false
}
