{
  "name": "@salty-css/eslint-plugin-core",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Vite plugin for Salty CSS",
  "homepage": "https://salty-css.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/margarita-form/salty-css.git",
    "directory": "libs/eslint-plugin-core"
  },
  "bugs": {
    "url": "https://github.com/margarita-form/salty-css/issues"
  },
  "version": "0.3.0-refactor-vite-8.4",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "test": "vitest run"
  },
  "dependencies": {
    "@salty-css/core": "0.3.0-refactor-vite-8.4",
    "@types/estree": "1.0.8",
    "eslint": ">=9.x || >=8.x || >=7.x"
  },
  "nx": {
    "targets": {
      "build": {
        "dependsOn": [
          "^build"
        ]
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "author": {
    "name": "Teemu Lahjalahti",
    "url": "https://www.linkedin.com/in/teemulahjalahti/"
  },
  "keywords": [
    "salty-css",
    "eslint",
    "eslint-plugin",
    "css-in-js",
    "linting"
  ],
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false
}
