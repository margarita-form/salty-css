{
  "name": "@salty-css/next",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Vite plugin for Salty CSS",
  "homepage": "https://salty-css.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/margarita-form/salty-css.git"
  },
  "bugs": {
    "url": "https://github.com/margarita-form/salty-css/issues"
  },
  "version": "0.2.2-refactor-vite-8.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "test": "vitest run"
  },
  "dependencies": {
    "@salty-css/core": "0.2.2-refactor-vite-8.1",
    "@salty-css/webpack": "0.2.2-refactor-vite-8.1"
  },
  "devDependencies": {
    "jsdom": "^29.1.1"
  },
  "nx": {
    "targets": {
      "build": {
        "dependsOn": [
          "^build"
        ]
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./config": {
      "import": "./dist/config.js",
      "require": "./dist/config.cjs"
    },
    "./factories": {
      "import": "./dist/factories.js",
      "require": "./dist/factories.cjs"
    },
    "./helpers": {
      "import": "./dist/helpers.js",
      "require": "./dist/helpers.cjs"
    },
    "./keyframes": {
      "import": "./dist/keyframes.js",
      "require": "./dist/keyframes.cjs"
    },
    "./media": {
      "import": "./dist/media.js",
      "require": "./dist/media.cjs"
    },
    "./runtime": {
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.cjs"
    }
  }
}