{
  "name": "@salty-css/next",
  "version": "0.2.0-alpha.2",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "typings": "./dist/index.d.ts",
  "type": "module",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Next.js plugin for Salty CSS",
  "homepage": "https://salty-css.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/margarita-form/salty-css.git"
  },
  "bugs": {
    "url": "https://github.com/margarita-form/salty-css/issues"
  },
  "files": [
    "**/*",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "sourceRoot": "libs/next/src",
    "name": "next"
  },
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.cjs"
    },
    "./config": {
      "import": "./config.js",
      "require": "./config.cjs"
    },
    "./factories": {
      "import": "./factories.js",
      "require": "./factories.cjs"
    },
    "./helpers": {
      "import": "./helpers.js",
      "require": "./helpers.cjs"
    },
    "./keyframes": {
      "import": "./keyframes.js",
      "require": "./keyframes.cjs"
    },
    "./media": {
      "import": "./media.js",
      "require": "./media.cjs"
    },
    "./runtime": {
      "import": "./runtime.js",
      "require": "./runtime.cjs"
    }
  },
  "dependencies": {
    "@salty-css/core": "0.2.0-alpha.2",
    "@salty-css/webpack": "0.2.0-alpha.2"
  }
}
