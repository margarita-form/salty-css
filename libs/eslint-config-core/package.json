{
  "name": "@salty-css/eslint-config-core",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "test": "vitest run"
  },
  "dependencies": {
    "@salty-css/core": "0.1.0",
    "@salty-css/eslint-plugin-core": "0.1.0",
    "eslint": ">=9.x || >=8.x || >=7.x"
  },
  "nx": {
    "targets": {
      "build": {
        "dependsOn": [
          "^build"
        ]
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./flat": {
      "import": "./dist/flat.js",
      "require": "./dist/flat.cjs"
    }
  }
}